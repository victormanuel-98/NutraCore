{
    "name": "nutracore-server",
    "version": "1.0.0",
    "description": "Backend API para NutraCore - Dashboard de NutriciÃ³n",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "seed": "node seed.js",
        "create-admin": "node scripts/create-admin.js",
        "clean-db": "node scripts/clean-db.js",
        "test": "jest --runInBand",
        "test:unit": "jest --runInBand tests/unit",
        "test:integration": "jest --runInBand tests/integration",
        "test:e2e": "jest --runInBand tests/e2e",
        "test:coverage": "jest --runInBand --coverage",
        "test:coverage:70": "jest --runInBand --coverage --coverageThreshold \"{\\\"global\\\":{\\\"branches\\\":55,\\\"functions\\\":70,\\\"lines\\\":70,\\\"statements\\\":70}}\""
    },
    "keywords": [
        "nutrition",
        "health",
        "fitness",
        "api",
        "mongodb"
    ],
    "author": "TFG NutraCore",
    "license": "MIT",
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cloudinary": "^2.9.0",
        "cors": "^2.8.6",
        "dotenv": "^16.6.1",
        "express": "^4.22.1",
        "express-mongo-sanitize": "^2.2.0",
        "helmet": "^8.1.0",
        "hpp": "^0.2.3",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^8.23.1",
        "nodemailer": "^8.0.7"
    },
    "devDependencies": {
        "jest": "^30.3.0",
        "mongodb-memory-server": "^11.1.0",
        "nodemon": "^3.0.1",
        "supertest": "^7.2.2"
    },
    "engines": {
        "node": ">=16.0.0"
    },
    "jest": {
        "testEnvironment": "node",
        "collectCoverageFrom": [
            "routes/**/*.js",
            "middleware/**/*.js",
            "services/**/*.js",
            "config/**/*.js",
            "models/**/*.js",
            "!**/node_modules/**"
        ]
    }
}