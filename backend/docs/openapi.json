{
  "openapi": "3.0.3",
  "info": {
    "title": "NutraCore API",
    "version": "1.0.0",
    "description": "Documentacion OpenAPI del backend NutraCore"
  },
  "servers": [
    {
      "url": "http://localhost:5000",
      "description": "Local"
    }
  ],
  "tags": [
    { "name": "System" },
    { "name": "Auth" },
    { "name": "Users" },
    { "name": "Recipes" },
    { "name": "Reviews" },
    { "name": "News" },
    { "name": "Dishes" },
    { "name": "Ingredients" },
    { "name": "Docs" }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": ["System"],
        "summary": "Info base de la API",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "version": { "type": "string" },
                    "endpoints": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["System"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "timestamp": { "type": "string", "format": "date-time" },
                    "mongodb": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/docs": {
      "get": {
        "tags": ["Docs"],
        "summary": "UI de Swagger",
        "responses": {
          "200": {
            "description": "HTML swagger"
          }
        }
      }
    },
    "/api/docs/openapi.json": {
      "get": {
        "tags": ["Docs"],
        "summary": "Especificacion OpenAPI",
        "responses": {
          "200": {
            "description": "JSON OpenAPI"
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Registrar usuario",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthRegisterRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Usuario registrado" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthLoginRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Login OK" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/auth/verify-email": {
      "get": {
        "tags": ["Auth"],
        "summary": "Verificar correo",
        "parameters": [
          { "name": "token", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "email", "in": "query", "required": true, "schema": { "type": "string", "format": "email" } }
        ],
        "responses": {
          "200": { "description": "Correo verificado" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/auth/resend-verification": {
      "post": {
        "tags": ["Auth"],
        "summary": "Reenviar verificacion",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": { "type": "string", "format": "email" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Correo reenviado" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Usuario autenticado actual",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Perfil actual" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Sesion cerrada" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/auth/change-password": {
      "put": {
        "tags": ["Auth"],
        "summary": "Cambiar contrasena",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["currentPassword", "newPassword"],
                "properties": {
                  "currentPassword": { "type": "string" },
                  "newPassword": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Contrasena actualizada" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/users/profile": {
      "get": {
        "tags": ["Users"],
        "summary": "Perfil del usuario",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Perfil OK" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Actualizar perfil",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserProfileUpdateRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Perfil actualizado" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/users/goals": {
      "put": {
        "tags": ["Users"],
        "summary": "Actualizar objetivos",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserGoalsUpdateRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Objetivos actualizados" }
        }
      }
    },
    "/api/users/stats": {
      "get": {
        "tags": ["Users"],
        "summary": "Estadisticas del usuario",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Stats OK" }
        }
      }
    },
    "/api/users/account": {
      "delete": {
        "tags": ["Users"],
        "summary": "Desactivar cuenta propia",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Cuenta desactivada" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/users/preferences": {
      "put": {
        "tags": ["Users"],
        "summary": "Actualizar preferencias",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserPreferencesUpdateRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Preferencias actualizadas" }
        }
      }
    },
    "/api/users/admin/list": {
      "get": {
        "tags": ["Users"],
        "summary": "Listar usuarios (admin)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Listado de usuarios" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/users/admin/{id}": {
      "get": {
        "tags": ["Users"],
        "summary": "Detalle usuario (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdParam" }],
        "responses": {
          "200": { "description": "Usuario encontrado" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Eliminar usuario (soft-delete, admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdParam" }],
        "responses": {
          "200": { "description": "Usuario eliminado" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/users/admin/{id}/status": {
      "patch": {
        "tags": ["Users"],
        "summary": "Suspender/activar usuario (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdParam" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "isActive": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Estado actualizado" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/users/admin/{id}/restore": {
      "patch": {
        "tags": ["Users"],
        "summary": "Restaurar usuario (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdParam" }],
        "responses": {
          "200": { "description": "Usuario restaurado" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/users/admin/audit/logs": {
      "get": {
        "tags": ["Users"],
        "summary": "Logs de auditoria (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 200 }
          }
        ],
        "responses": {
          "200": { "description": "Lista de logs" }
        }
      }
    },
    "/api/recipes": {
      "get": {
        "tags": ["Recipes"],
        "summary": "Listar recetas",
        "parameters": [
          { "name": "category", "in": "query", "schema": { "type": "string" } },
          { "name": "difficulty", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "author", "in": "query", "schema": { "type": "string" } },
          { "name": "favorites", "in": "query", "schema": { "type": "string", "enum": ["true", "false"] } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 12 } },
          { "name": "sort", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Listado de recetas" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Recipes"],
        "summary": "Crear receta",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RecipeUpsertRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Receta creada" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/recipes/user/me": {
      "get": {
        "tags": ["Recipes"],
        "summary": "Recetas del usuario autenticado",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Recetas propias" }
        }
      }
    },
    "/api/recipes/user/favorites": {
      "get": {
        "tags": ["Recipes"],
        "summary": "Recetas favoritas del usuario autenticado",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Favoritos" }
        }
      }
    },
    "/api/recipes/featured/popular": {
      "get": {
        "tags": ["Recipes"],
        "summary": "Recetas populares destacadas",
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 12 } }
        ],
        "responses": {
          "200": { "description": "Recetas destacadas" }
        }
      }
    },
    "/api/recipes/tags/available": {
      "get": {
        "tags": ["Recipes"],
        "summary": "Tags disponibles para recetas",
        "responses": {
          "200": { "description": "Listado de tags" }
        }
      }
    },
    "/api/recipes/{id}": {
      "get": {
        "tags": ["Recipes"],
        "summary": "Detalle receta por ID",
        "parameters": [{ "$ref": "#/components/parameters/IdParam" }],
        "responses": {
          "200": { "description": "Receta" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Recipes"],
        "summary": "Actualizar receta",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdParam" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RecipeUpsertRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Receta actualizada" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Recipes"],
        "summary": "Eliminar receta (soft-delete)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdParam" }],
        "responses": {
          "200": { "description": "Receta eliminada" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/recipes/{id}/favorite": {
      "post": {
        "tags": ["Recipes"],
        "summary": "Toggle favorito en receta",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdParam" }],
        "responses": {
          "200": { "description": "Favorito actualizado" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/recipes/{id}/restore": {
      "patch": {
        "tags": ["Recipes"],
        "summary": "Restaurar receta (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdParam" }],
        "responses": {
          "200": { "description": "Receta restaurada" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/reviews": {
      "post": {
        "tags": ["Reviews"],
        "summary": "Crear o actualizar valoracion",
        "security": [{ "bearerAuth": [] }],
