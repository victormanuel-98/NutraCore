        "tags": ["Reviews"],
        "summary": "Listar valoraciones por receta",
        "parameters": [
          {
            "name": "recipeId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Valoraciones" }
        }
      }
    },
    "/api/reviews/{id}": {
      "delete": {
        "tags": ["Reviews"],
        "summary": "Eliminar valoracion",
