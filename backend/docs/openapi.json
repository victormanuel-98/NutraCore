    "/api/ingredients/search": {
      "get": {
        "tags": ["Ingredients"],
        "summary": "Buscar ingredientes en Open Food Facts",
        "parameters": [
          { "name": "q", "in": "query", "required": true, "schema": { "type": "string", "minLength": 2 } },
