    "/api/dishes": {
      "get": {
        "tags": ["Dishes"],
        "summary": "Listar platos",
        "parameters": [
          { "name": "category", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "tags", "in": "query", "schema": { "type": "string" } },
          { "name": "minCalories", "in": "query", "schema": { "type": "number" } },
          { "name": "maxCalories", "in": "query", "schema": { "type": "number" } },
          { "name": "difficulty", "in": "query", "schema": { "type": "string" } },
          { "name": "featured", "in": "query", "schema": { "type": "string", "enum": ["true", "false"] } },
          { "name": "sort", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1 } }
        ],
        "responses": {
          "200": { "description": "Platos listados" }
